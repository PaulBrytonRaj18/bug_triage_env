# bug_triage_env/.env.example
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — add it to .gitignore.
#
# These variables are required by:
#   inference.py       — the baseline agent script
#   The hackathon judges during automated evaluation
#
# The judges will set these variables in their own environment
# before running your inference.py. Make sure your script
# reads them exactly as named below.

# ---------------------------------------------------------------
# LLM endpoint — the base URL of the OpenAI-compatible API
# Examples:
#   https://api.openai.com/v1
#   https://api-inference.huggingface.co/models/meta-llama/Llama-3.1-8B-Instruct/v1
# ---------------------------------------------------------------
API_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------
# Model identifier — the model the inference script will use
# Examples:
#   gpt-4o-mini
#   meta-llama/Llama-3.1-8B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
# ---------------------------------------------------------------
MODEL_NAME=gpt-4o-mini

# ---------------------------------------------------------------
# API key — your HuggingFace token or OpenAI API key
# ---------------------------------------------------------------
HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------
# Environment URL — where the running environment is accessible
# Default: http://localhost:7860 for local development
# In production: your HuggingFace Space URL
# ---------------------------------------------------------------
ENV_URL=http://localhost:7860
